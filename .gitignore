# Секреты — никогда не коммитить в репозиторий!
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
build/

# Тесты и отладка
.pytest_cache/
.coverage
htmlcov/
*.log

# Логи и данные бота (SQLite, лог-файлы)
# Папка logs/ в репо есть (см. logs/.gitkeep), сами файлы *.log не коммитим
logs/*
!logs/.gitkeep
data/

# Загруженные аватары (веб-профиль)
web/static/uploads/

# IDE и ОС
.idea/
.vscode/
.DS_Store
*.swp
*.swo
