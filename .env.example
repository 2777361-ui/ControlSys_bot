# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Секрет для JWT веб-сессий. В проде обязательно задать свою случайную строку (не использовать дефолт из кода).
# Пример: openssl rand -hex 32
WEB_SECRET_KEY=

# База данных (продакшен). Если задана — используется PostgreSQL (Supabase), иначе локальный SQLite (data/school.db).
# Supabase: Project Settings → Database → Connection string (URI). Формат: postgresql://user:pass@host:5432/postgres
# DATABASE_URL=

# Публичный URL веб-интерфейса (для ссылок приглашения родителей и сброса пароля). В проде — https://ваш-сервис.onrender.com
# BASE_URL=https://your-web-service.onrender.com

# Ключ Context7 для MCP (Cursor). Этот же ключ нужно подставить в настройках Cursor: MCP → context7.
CONTEXT7_API_KEY=your_context7_api_key_here
